      "radial-gradient(ellipse 40% 50% at 90% 80%, rgba(255,208,0,0.025) 0%, transparent 60%)"
    ]
  },

  "explore": {
    "defaultCityId": "bangkok",
    "defaultCatFilter": "all",
    "allCategoryOption": { "id": "all", "label": "All", "emoji": "🍽️" },
    "restaurantListMaxHeight": "260px",
    "cityLabel": "Select by City",
    "storeLabel": "Select a Department Store",
    "categoryLabel": "Filter by Category",
    "backAriaLabel": "Back to store list",
    "selectAllLabel": "Select all",
    "clearSelectionLabel": "Clear",
    "noRestaurantsLabel": "No restaurants in this category",
    "addButtonPrefix": "+ Add",
    "addAllSuffix": "all",
    "addSelectedSuffix": "selected",
    "spinButtonSuffix": "→"
  }
